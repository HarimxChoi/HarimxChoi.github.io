---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  lang?: "en" | "ko";
}

const {
  title = "Harim Choi · Production ML Engineer",
  description = "ML Engineer, 6+ years end-to-end production across CV, NLP, predictive modeling. Open-source agent infra (MCP), Korean public-procurement ML, decision-science systems research.",
  lang = "en",
} = Astro.props;
---

<!doctype html>
<html lang={lang} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://harimxchoi.github.io" />
    <meta property="og:image" content="https://harimxchoi.github.io/img/og.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-zinc-950 text-zinc-100 font-sans antialiased min-h-screen light">
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem("portfolio-mode");
          if (saved === "dark") document.body.classList.remove("light");
          else if (saved === "light") document.body.classList.add("light");
        } catch (e) {}
      })();
    </script>
    <slot />
  </body>
</html>
