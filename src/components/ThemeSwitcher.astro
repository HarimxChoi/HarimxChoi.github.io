---
const lang = Astro.props.lang ?? "en";
const otherLangHref = lang === "en" ? "/ko/" : "/";
const otherLangLabel = lang === "en" ? "한국어" : "English";
---

<div class="fixed top-3 right-3 z-50 flex items-center gap-1 p-1 rounded-full border border-zinc-700 bg-zinc-900/80 backdrop-blur text-xs font-mono">
  <a
    href={otherLangHref}
    class="px-3 py-1 rounded-full hover:bg-zinc-700 transition-colors"
    aria-label={`Switch to ${otherLangLabel}`}
  >
    {otherLangLabel}
  </a>
  <button
    id="theme-toggle"
    type="button"
    class="w-7 h-7 flex items-center justify-center rounded-full hover:bg-zinc-700 transition-colors"
    aria-label="Toggle light / dark mode"
  >
    <svg id="icon-sun" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="4"/>
      <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
    </svg>
    <svg id="icon-moon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
    </svg>
  </button>
</div>

<script is:inline>
  (function () {
    const btn = document.getElementById("theme-toggle");
    if (!btn) return;
    const sun = document.getElementById("icon-sun");
    const moon = document.getElementById("icon-moon");
    const sync = () => {
      const isLight = document.body.classList.contains("light");
      if (sun) sun.style.display = isLight ? "" : "none";
      if (moon) moon.style.display = isLight ? "none" : "";
    };
    sync();
    btn.addEventListener("click", () => {
      const next = document.body.classList.contains("light") ? "dark" : "light";
      document.body.classList.toggle("light", next === "light");
      sync();
      try { localStorage.setItem("portfolio-mode", next); } catch (e) {}
    });
  })();
</script>
